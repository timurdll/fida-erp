# ──────────────────────────────────────────────────────────────────────────────
# FIDA ERP — production environment
# Скопировать в .env.production и заполнить:  cp .env.production.example .env.production
# Файл .env.production НЕ коммитить (он в .gitignore по маске .env.*).
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (читаются контейнером postgres) ────────────────────────────────
POSTGRES_USER=fida
# ОБЯЗАТЕЛЬНО заменить на надёжный пароль. Сгенерировать:  openssl rand -base64 24
POSTGRES_PASSWORD=
POSTGRES_DB=fida_erp

# ── Backend ───────────────────────────────────────────────────────────────────
# Хост = postgres (имя docker-сервиса), НЕ localhost.
# Пароль/пользователь/база ДОЛЖНЫ совпадать с POSTGRES_* выше.
DATABASE_URL="postgresql://fida:ЗАМЕНИТЬ_ПАРОЛЬ@postgres:5432/fida_erp?schema=public"

# ОБЯЗАТЕЛЬНО ЗАМЕНИТЬ — сгенерировать командой:  openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

PORT=3001

# Origin для CORS (так называется переменная в коде main.ts).
# Эквивалент CORS_ORIGIN из ТЗ.
FRONTEND_URL=https://erp.fida-group.kz

# ── Frontend ──────────────────────────────────────────────────────────────────
# ВНИМАНИЕ: эта переменная встраивается в JS-бандл на этапе `docker build`
# (значение продублировано в docker-compose.prod.yml → frontend.build.args).
# Менять её здесь без пересборки фронтенда смысла не имеет.
NEXT_PUBLIC_API_URL=https://erp.fida-group.kz/api
